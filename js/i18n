  try{localStorage.setItem('haititps_lang',lang)}catch(e){}
  document.querySelectorAll('[data-i18n]').forEach(function(el){
    var key=el.getAttribute('data-i18n');
    if(T[key]&&T[key][lang]){
      if(T[key][lang].indexOf('<')>-1){el.innerHTML=T[key][lang]}
      else{el.textContent=T[key][lang]}
    }
  });
  document.querySelectorAll('.lang-btn').forEach(function(b){
    b.classList.toggle('active',b.getAttribute('data-lang')===lang);
  });
  document.documentElement.lang=lang;
  if(typeof window.onLangChange==='function') window.onLangChange(lang);
}

function initI18n(){
  var saved;
  try{saved=localStorage.getItem('haititps_lang')}catch(e){}
  if(saved&&T.hero_badge[saved]) currentLang=saved;
  document.querySelectorAll('.lang-btn').forEach(function(btn){
    btn.addEventListener('click',function(){setLang(this.getAttribute('data-lang'))});
  });
  setLang(currentLang);
}

if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initI18n)}
else{initI18n()}

window.HT_i18n={T:T,setLang:setLang,getLang:function(){return currentLang}};
})();
